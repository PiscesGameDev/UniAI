  m_Script: {fileID: 11500000, guid: c77e6be9e6fbc0b4495dfa70186e5d50, type: 3}
  m_Name: PrefabEditTool
  m_EditorClassIdentifier: UniAI.Editor::UniAI.Editor.Tools.PrefabEditTool
  _toolName: prefab_edit
  _description: "\u9884\u5236\u4F53\u751F\u547D\u5468\u671F\u64CD\u4F5C\uFF1A\u628A\u573A\u666F
    GameObject \u4FDD\u5B58\u4E3A\u9884\u5236\u4F53\u3001\u5B9E\u4F8B\u5316\u9884\u5236\u4F53\u5230\u573A\u666F\u3001\u62C6\u5305\u9884\u5236\u4F53\u5B9E\u4F8B\u3001\u5E94\u7528\u6216\u56DE\u6EDA\u9884\u5236\u4F53\u5B9E\u4F8B\u7684
    override\u3002\u4EC5 Edit Mode \u53EF\u7528\u3002"
  _parametersSchema: "{                                                         \r\n   
    \"type\": \"object\",\r\n    \"properties\": {\r\n      \"action\": {\r\n       
    \"type\": \"string\",\r\n        \"enum\": [\"create_from_gameobject\",\"instantiate\",\"unpack\",\"apply_overrides\",\"revert_overrides\"]\r\n     
    },                                                                                                                                                                                                                                   
    \r\n      \"path\": { \"type\": \"string\", \"description\": \"\u573A\u666F GameObject
    \u7684\u5C42\u7EA7\u8DEF\u5F84\" },\r\n      \"save_path\": { \"type\": \"string\",
    \"description\": \"\u9884\u5236\u4F53 Asset \u8DEF\u5F84\uFF0C\u5FC5\u987B\u4EE5
    'Assets/' \u5F00\u5934\u4E14\u4EE5 '.prefab' \u7ED3\u5C3E\" },                                                                                                                     
    \r\n      \"parent\": { \"type\": \"string\", \"description\": \"instantiate
    \u540E\u6302\u5230\u7684\u7236\u8282\u70B9\u8DEF\u5F84\" },                                                                                                                                                     
    \r\n      \"name\": { \"type\": \"string\", \"description\": \"instantiate \u540E\u7684\u5B9E\u4F8B\u540D\u79F0\"
    },                                                                                                                                                             
    \r\n      \"position\": { \"type\": \"array\", \"items\": { \"type\": \"number\"
    }, \"description\": \"instantiate \u7684\u521D\u59CB localPosition [x,y,z]\"
    },                                                                                                           
    \r\n      \"mode\": { \"type\": \"string\", \"enum\": [\"outermost\",\"completely\"],
    \"description\": \"unpack \u6A21\u5F0F\uFF0C\u9ED8\u8BA4 outermost\" }                                                                                                                       
    \r\n    },                                                                                                                                                                                                                                     
    \r\n    \"required\": [\"action\"]                                                                                                                                                                                                                 
    \r\n  }      "
