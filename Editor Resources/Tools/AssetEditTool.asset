  m_Script: {fileID: 11500000, guid: 6d480d3c858f83c45a1d1596b8efd915, type: 3}
  m_Name: AssetEditTool
  m_EditorClassIdentifier: UniAI.Editor::UniAI.Editor.Tools.AssetEditTool
  _toolName: asset_edit
  _description: "AssetDatabase \u5143\u64CD\u4F5C\uFF1A\u521B\u5EFA\u6587\u4EF6\u5939\u3001\u590D\u5236/\u79FB\u52A8/\u91CD\u547D\u540D/\u5220\u9664\u8D44\u4EA7\u3001\u5237\u65B0\u3001\u6309
    filter \u67E5\u627E\u3001\u67E5\u8BE2\u4F9D\u8D56\u3001GUID \u4E0E\u8DEF\u5F84\u4E92\u8F6C\u3002\u9002\u7528\u4E8E\u6574\u7406\u9879\u76EE\u7ED3\u6784\u6216\u6279\u91CF\u5904\u7406\u8D44\u4EA7\u3002\u6240\u6709\u8DEF\u5F84\u5FC5\u987B\u4EE5
    'Assets/' \u5F00\u5934\u3002"
  _parametersSchema: "{\r\n    \"type\": \"object\",\r\n    \"properties\": {\r\n     
    \"action\": {                                                                                                                                                                                                                          
    \r\n        \"type\": \"string\",\r\n        \"enum\": [\"create_folder\",\"copy\",\"move\",\"rename\",\"delete\",\"refresh\",\"find\",\"dependencies\",\"guid_to_path\",\"path_to_guid\"]                                                                                                            
    \r\n      },                                                                                                                                                                                                                                   
    \r\n      \"path\": { \"type\": \"string\", \"description\": \"\u8D44\u4EA7\u8DEF\u5F84\uFF1Bcreate_folder
    \u65F6\u4E3A\u8981\u521B\u5EFA\u7684\u65B0\u6587\u4EF6\u5939\u8DEF\u5F84\" },\r\n     
    \"from\": { \"type\": \"string\", \"description\": \"copy/move \u7684\u6E90\u8DEF\u5F84\"
    },                                                                                                                                                                   
    \r\n      \"to\": { \"type\": \"string\", \"description\": \"copy/move \u7684\u76EE\u6807\u8DEF\u5F84\"
    },                                                                                                                                                                   
    \r\n      \"new_name\": { \"type\": \"string\", \"description\": \"rename \u7684\u65B0\u6587\u4EF6\u540D\uFF08\u4E0D\u542B\u8DEF\u5F84\u548C\u6269\u5C55\u540D\uFF09\"
    },                                                                                                                                            
    \r\n      \"filter\": { \"type\": \"string\", \"description\": \"find \u8FC7\u6EE4\u8868\u8FBE\u5F0F\uFF0C\u5982
    't:Prefab'\u3001'MyIcon t:Sprite'\" },                                                                                                                                  
    \r\n      \"folders\": { \"type\": \"array\", \"items\": { \"type\": \"string\"
    }, \"description\": \"find \u7684\u641C\u7D22\u8303\u56F4\" },                                                                                                                                     
    \r\n      \"recursive\": { \"type\": \"boolean\", \"description\": \"dependencies
    \u662F\u5426\u9012\u5F52\uFF0C\u9ED8\u8BA4 false\" },                                                                                                                                              
    \r\n      \"guid\": { \"type\": \"string\", \"description\": \"guid_to_path \u7684
    GUID\" }                                                                                                                                                                  
    \r\n    },                                                                                                                                                                                                                                     
    \r\n    \"required\": [\"action\"]                                  \r\n  }    "
