  _toolName: project_settings
  _description: " \u8BFB\u5199 Unity \u9879\u76EE\u8BBE\u7F6E\uFF1ATags / Layers
    / Physics / Time / Quality\u3002\u4FEE\u6539\u540E\u81EA\u52A8\u6301\u4E45\u5316\u5230
    ProjectSettings \u76EE\u5F55\u3002Layers 0-7 \u662F\u5185\u7F6E\u5C42\uFF0C\u4E0D\u53EF\u4FEE\u6539\u3002"
  _parametersSchema: " {\r\n    \"type\": \"object\",                                                                                                                                                                                                                      
    \r\n    \"properties\": {                                                                                                                                                                                                                      
    \r\n      \"action\": {  \r\n        \"type\": \"string\",\r\n        \"enum\":
    [\"list_tags\",\"add_tag\",\"remove_tag\",\"list_layers\",\"set_layer\",\"get_physics\",\"set_physics\",\"get_time\",\"set_time\",\"get_quality\",\"set_quality\"]\r\n     
    },                                                                                                                                                   
    \r\n      \"name\": { \"type\": \"string\", \"description\": \"add_tag/remove_tag
    \u7684\u6807\u7B7E\u540D\uFF1Bset_layer \u7684\u5C42\u540D\" },                                                                                                                                        
    \r\n      \"index\": { \"type\": \"integer\", \"description\": \"set_layer \u7684\u5C42\u7D22\u5F15\uFF088-31\uFF0C0-7
    \u4E3A\u5185\u7F6E\u5C42\uFF09\" },   \r\n      \"property\": {                                                                                                                                                                                                                        
    \r\n        \"type\": \"string\",                                                                                                                                                                                                                  
    \r\n        \"description\": \"set_physics: gravity/bounceThreshold/defaultSolverIterations/defaultSolverVelocityIterations/sleepThreshold/defaultContactOffset\uFF1Bset_time:
    fixedDeltaTime/maximumDeltaTime/timeScale\uFF1Bset_quality:                 \r\n 
    level/vSyncCount/antiAliasing/shadowDistance\"                                                                                                                                                                                            
    \r\n      },                                                                                                                                                                                                                                   
    \r\n      \"value\": { \"description\": \"\u76EE\u6807\u503C\u3002gravity \u7528
    [x,y,z]\uFF0C\u5176\u4ED6\u6309 number/int\" }\r\n    },                                                                                                                                                                                                                                     
    \r\n    \"required\": [\"action\"]                                                                                                                                                                                                                 
    \r\n  }\r\n"
