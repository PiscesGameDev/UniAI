  m_Script: {fileID: 11500000, guid: f2e3d4c5b6a7189900a1b2c3d4e5f6a7, type: 3}
  m_Name: RunTestsTool
  m_EditorClassIdentifier: UniAI.Editor::UniAI.Editor.Tools.RunTestsTool
  _toolName: run_tests
  _description: "Run Unity tests and return results. EditMode tests run directly
    in the current editor (fast). PlayMode tests run in a separate Unity subprocess
    to avoid interrupting the session. Use 'both' to run both sequentially."
  _parametersSchema: '{"type":"object","properties":{"mode":{"type":"string","enum":["editmode","playmode","both"],"description":"Test
    mode. editmode (default) runs in current editor. playmode runs in a subprocess.
    both runs editmode first then playmode."},"test_filter":{"type":"string","description":"Optional
    test name or pattern to filter which tests to run."}},"required":[]}'
