  _description: " \u8BFB\u53D6\u6216\u8BBE\u7F6E Unity \u5F53\u524D Selection\uFF08Hierarchy
    \u4E2D\u9009\u4E2D\u7684 GameObject \u6216 Project \u4E2D\u9009\u4E2D\u7684\u8D44\u4EA7\uFF09\u3002\u7528\u6237\u5728\u7F16\u8F91\u5668\u91CC\u624B\u52A8\u9009\u4E2D\u7269\u4F53\u540E\uFF0C\u5BF9\u8BDD\u91CC\u8BF4\"\u7ED9\u5B83\u52A0\u7EC4\u4EF6\"\u65F6\u7528
    action=get \u53EF\u8BC6\u522B\u6307\u4EE3\u5BF9\u8C61\u3002action=set \u53EF\u6309\u5C42\u7EA7\u8DEF\u5F84\u6216
    asset \u8DEF\u5F84\u8BBE\u7F6E\u9009\u4E2D\u3002"
  _parametersSchema: "{\r\n    \"type\": \"object\",                                                                                                                                                                                                                      
    \r\n    \"properties\": {                                                                                                                                                                                                                      
    \r\n      \"action\": {                                                                                                                                                                                                                          
    \r\n        \"type\": \"string\",                                                                                                                                                                                                                
    \r\n        \"enum\": [\"get\",\"set\",\"clear\",\"get_assets\"],\r\n       
    \"description\": \"get=\u8BFB\u53D6\u5F53\u524D Selection\uFF08\u542B\u573A\u666F\u5BF9\u8C61\u548C\u8D44\u4EA7\uFF09\uFF1Bset=\u6309\u8DEF\u5F84\u8BBE\u7F6E\u9009\u4E2D\uFF1Bclear=\u6E05\u7A7A\u9009\u4E2D\uFF1Bget_assets=\u53EA\u8BFB\u53D6
    Project \u7A97\u53E3\u9009\u4E2D\u7684\u8D44\u4EA7\"\r\n      },                                                                                                                                        
    \r\n      \"paths\": {                                                                                                                                                                                                                           
