  _toolName: scriptable_object_edit
  _description: "\u901A\u7528 ScriptableObject \u5C5E\u6027\u7F16\u8F91\uFF1A\u5217\u51FA\u5B57\u6BB5\u3001\u8BFB\u53D6\u5355\u4E2A\u5B57\u6BB5\u503C\u3001\u6309\u5B57\u6BB5\u540D\u8D4B\u503C\u3002\u57FA\u4E8E
    SerializedObject\uFF0C\u53EF\u7F16\u8F91 [SerializeField] private \u5B57\u6BB5\uFF0C\u81EA\u52A8
    Undo \u548C\u4FDD\u5B58\u3002\u652F\u6301\u57FA\u7840\u7C7B\u578B\u3001Vector2/3/4\u3001Color\u3001Quaternion\uFF08\u6B27\u62C9\u89D2\uFF09\u3001Enum\u3001ObjectReference\uFF08\u4F20\r\n 
    asset \u8DEF\u5F84\uFF09\u3001LayerMask\u3001Rect\u3002\u4EC5 Edit Mode \u53EF\u7528\u3002"
  _parametersSchema: " {                                                                                                                                                                                                                                        
    \r\n    \"type\": \"object\",                                                                                                                                                                                                                    
    \r\n    \"properties\": {  \r\n      \"action\": {  \r\n        \"type\": \"string\",                                                                                                                                                                                                                  
    \r\n        \"enum\": [\"list_fields\",\"get\",\"set\"],\r\n        \"description\":
    \"list_fields=\u5217\u51FA SO \u7684\u6240\u6709\u53EF\u7F16\u8F91\u5B57\u6BB5\u53CA\u7C7B\u578B\uFF1Bget=\u8BFB\u53D6\u5355\u4E2A\u5B57\u6BB5\uFF1Bset=\u8D4B\u503C\"                                                                                                                                            
    \r\n      },                                                                                                                                                                                                                                 
    \r\n      \"path\": {                                                                                                                                                                                                                            
    \r\n        \"type\": \"string\",\r\n        \"description\": \"ScriptableObject
    Asset \u8DEF\u5F84\uFF0C\u5982 'Assets/Configs/GameConfig.asset'\"                                                                                                                                                 
    \r\n      },                                                                                                                                                                                                                                 
    \r\n      \"property\": {                                                                                                                                                                                                                        
    \r\n        \"type\": \"string\",\r\n        \"description\": \"\u5B57\u6BB5\u540D\uFF08\u5BF9\u5E94
    Inspector \u663E\u793A\u7684\u540D\u79F0\uFF0C\u901A\u5E38\u662F '_xxx' \u6216
    'xxx'\uFF0C\u4EE5 list_fields \u7ED3\u679C\u4E3A\u51C6\uFF09\"                                                                                                                              
    \r\n      },                                                                                                                                                                                                                                 
    \r\n      \"value\": {                                                                                                                                                                                                                           
    \r\n        \"description\": \"set \u65F6\u7684\u76EE\u6807\u503C\u3002int/float/bool/string
    \u76F4\u63A5\u4F20\uFF1BVector3=[x,y,z]\uFF1BColor=[r,g,b,a]\uFF1BQuaternion
    \u4F20\u6B27\u62C9\u89D2 [x,y,z]\uFF1BEnum \u4F20\u5B57\u7B26\u4E32\u540D\u6216\u7D22\u5F15\uFF1BObjectReference
    \u4F20 asset \u8DEF\u5F84\"\r\n      }                                                                                                                                                                                                                                    
    \r\n    },                                                                                                                                                                                                                                     
    \r\n    \"required\": [\"action\"]\r\n  }       "
