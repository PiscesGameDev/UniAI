  m_Script: {fileID: 11500000, guid: c010c010c010c010c010c010c010c010, type: 3}
  m_Name: ConsoleLogTool
  m_EditorClassIdentifier: UniAI.Editor::UniAI.Editor.Tools.ConsoleLogTool
  _toolName: console_log
  _description: "\u8BFB\u53D6 Unity Console \u65E5\u5FD7\uFF0C\u5305\u62EC\u8FD0\u884C\u65F6
    Debug.Log \u8F93\u51FA\u548C\u7F16\u8BD1\u9519\u8BEF/\u8B66\u544A\u3002\u7528\u4E8E\u5728\u4FEE\u6539\u4EE3\u7801\u6216\u8FD0\u884C\u540E\u786E\u8BA4\u6267\u884C\u7ED3\u679C\u3001\u6392\u67E5\u9519\u8BEF\u3002\u65E5\u5FD7\u5728
    Editor \u542F\u52A8\u540E\u81EA\u52A8\u6355\u83B7\uFF08\u6700\u591A 500 \u6761\u73AF\u5F62\u7F13\u51B2\uFF09\u3002\u9ED8\u8BA4
    action=get_recent \u8FD4\u56DE\u6700\u65B0\u65E5\u5FD7\u3002"
  _parametersSchema: " {                                                                                                                                                                                                                                        
    \r\n    \"type\": \"object\",                                                                                                                                                                                                                      
    \r\n    \"properties\": {                                                                                                                                                                                                                        
    \r\n      \"action\": {                                                                                                                                                                                                                        
    \r\n        \"type\": \"string\",\r\n        \"enum\": [\"get_recent\",\"get_errors\",\"get_warnings\",\"get_compile_errors\",\"count\",\"clear\"],\r\n       
    \"description\": \"get_recent=\u5168\u90E8\u6700\u65B0\u65E5\u5FD7\uFF1Bget_errors=\u53EA\u770B
    Error/Exception\uFF1Bget_warnings=\u53EA\u770B Warning\uFF1Bget_compile_errors=\u53EA\u770B
    C# \u7F16\u8BD1\u9519\u8BEF\uFF08\u4FEE\u6539\u4EE3\u7801\u540E\u5FC5\u770B\uFF09\uFF1Bcount=\u6309\u7EA7\u522B\u7EDF\u8BA1\uFF1Bclear=\u6E05\u7A7A\u7F13\u51B2\u533A\"\r\n     
    },                                                                                                                                                                                                                                   
    \r\n      \"limit\": {                                                                                                                                                                                                                           
    \r\n        \"type\": \"integer\",                                                                                                                                                                                                                 
    \r\n        \"description\": \"\u8FD4\u56DE\u6761\u6570\u4E0A\u9650\uFF0C\u9ED8\u8BA4
    30\"                                                                                                                                                                                             
    \r\n      }                                                                                                                                                                                                                                    
    \r\n    }, \r\n    \"required\": [\"action\"]                                                                                                                                                                                                                 
    \r\n  }           "
